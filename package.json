{
  "name": "zotero-snowball-sources",
  "version": "0.5.5",
  "private": true,
  "description": "Zotero plugin for OpenAlex forward and backward citation snowballing.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/socratic-irony/zotero-snowball.git"
  },
  "bugs": {
    "url": "https://github.com/socratic-irony/zotero-snowball/issues"
  },
  "homepage": "https://github.com/socratic-irony/zotero-snowball#readme",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "build": "bash scripts/build.sh",
    "validate:xpi": "bash scripts/validate-xpi.sh",
    "validate:manifest": "python3 -m json.tool src/manifest.json > /dev/null && xmllint --noout src/chrome/content/snowballDialog.xhtml && xmllint --noout src/chrome/content/snowballPrefs.xhtml",
    "bump": "bash scripts/bump-version.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm test && npm run validate:manifest",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n": "^17.14.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^15.12.0",
    "lefthook": "^1.8.4",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
